{
  "name": "routerx-admin",
  "version": "1.0.0",
  "description": "RouterX Admin - 会员订阅管理后台",
  "author": "Buhaoshawn",
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.routerx.admin",
    "productName": "RouterX Admin",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "frontend/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "electron-log": "^5.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "axios": "^1.15.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "vite": "^8.0.8",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  }
}
